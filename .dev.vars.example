# Copy to .dev.vars for local dev.

# Required: Better Auth signing secret (any long random string).
#   openssl rand -base64 32 | wrangler secret put BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=change-me-openssl-rand-base64-32

# Local dev: point Better Auth at your localhost origin so the session cookie
# isn't marked Secure (otherwise it won't be sent over http). Match `wrangler
# dev --port`. In production this comes from wrangler.jsonc vars instead.
BETTER_AUTH_URL=http://localhost:8787

# Local-dev only: with EMAIL_API_KEY unset, OTP_DEV_ECHO=1 logs the OTP to the
# console (and it's also in the local D1 verification table) so you can sign in
# without the email worker. NEVER set this in production — without it, missing
# EMAIL_API_KEY fails closed instead of leaking codes to logs.
OTP_DEV_ECHO=1

# cfEmailSender API key (x-api-key) for OTP email delivery via the EMAIL_SENDER
# service binding. Required in production (unless OTP_DEV_ECHO is set).
#   wrangler secret put EMAIL_API_KEY
# EMAIL_API_KEY=cfes_xxxxxxxx
